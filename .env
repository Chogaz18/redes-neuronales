# Dataset WFDB
WFDB_RECORDS_DIR=data/raw/WFDBRecords

# Número máximo de registros listados en exploración
SAMPLE_RECORD_COUNT=100

# Ventana temporal por defecto (s); en ECG de 10 s el máximo es 10
DEFAULT_WINDOW_DURATION_S=10.0
MIN_WINDOW_DURATION_S=1.0
MAX_WINDOW_DURATION_S=10.0

# Rango de bpm
HR_MIN_BPM=60
HR_MAX_BPM=100

# Lead preferido para detección de picos R
DEFAULT_RPEAK_LEAD=II
